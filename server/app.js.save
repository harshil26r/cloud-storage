import { open, readdir } from "fs/promises";
import http from "http";

const PORT = 4000;

const setHeader = (name, value, res) => {
  res.setHeader(name, value);
};

const parseURL = (req) => {
  const [url] = req?.url?.split("?");
  return url;
};

async function serveDirectory(req, res) {
  try {
    const items = await readdir(`./storage${parseURL(req)}`, {
      withFileTypes: true,sfa;slkfa'ffas;ldfk;sa
adaasdalkJFKSA;JFLSAFsdkfjalskdfjsadf

    const result = items.map((item) => ({
      name: item.name,
      type: item.isDirectory() ? "folder" : "file",
    }));

    setHeader("Content-Type", "application/json", res);
    res.end(JSON.stringify(result));
  } catch (error) {
    res.statusCode = 500;
    res.end(error.message);
  }
}

const handleGETRequest = async (req, res) => {
  if (req.url === "/favicon.ico") return res.end("No favicon.");
  if (req.url === "/") {
    serveDirectory(req, res);
  } else {
    try {
      const fileHandle = await open(
        `./storage${decodeURIComponent(parseURL(req))}`
      );
      const stats = await fileHandle.stat();
      if (stats.isDirectory()) {
        serveDirectory(req, res);
      } else {
        const readStream = fileHandle.createReadStream();
        readStream.pipe(res);
      }
      // fileHandle.close();
    } catch (err) {
      console.log(err.message);
      res.end("Not Found!");
    }
  }
};
const handlePOSTRequest = (req, res) => {};
const handleDELETERequest = (req, res) => {};
const handlePATCHRequest = (req, res) => {};
const handleOPTIONRequest = (req, res) => {};

const server = http.createServer(async (req, res) => {
  setHeader("Access-Control-Allow-Origin", "*", res);

  switch (req.method) {
    case "GET":
      handleGETRequest(req, res);
      break;
    case "POST":
      handlePOSTRequest(req, res);
      break;
    case "DELETE":
      handleDELETERequest(req, res);
      break;
    case "PATCH":
      handlePATCHRequest(req, res);
      break;
    case "OPTION":
      handleOPTIONRequest(req, res);
      break;
  }
});

server.listen(PORT, () => {
  console.log(`Server started on ${PORT}`);
});
